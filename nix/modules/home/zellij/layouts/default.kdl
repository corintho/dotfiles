layout {
  default_tab_template {
      pane size=1 borderless=true {
          plugin location="zjstatus"
      }
      children
  }
  tab name="main" {
    pane stacked=true {
      pane command="hx" {
        args "."
      }
      pane
      pane
    }
  }
  tab name="agent" {
    pane command="opencode" start_suspended=true {
      args "--continue"
    }
  }
}
